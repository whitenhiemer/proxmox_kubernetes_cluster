---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Layout
  title="Writing"
  description="Notes on AI automation, systems design, and engineering operations from Brandon Woodward."
>
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Writing</div>
      <h1>Notes on building better systems.</h1>
      <p class="hero-sub">AI automation, on-call ops, and the engineering decisions that actually matter.</p>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <div class="post-list">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-read">Read post →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .page-hero h1 { font-size: clamp(2rem, 4vw, 2.75rem); margin-bottom: 1rem; }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--dim);
    max-width: 540px;
    line-height: 1.6;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-card {
    display: block;
    text-decoration: none;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: none;
  }

  .post-card:first-child { padding-top: 2rem; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .post-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }

  .post-title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 0.6rem;
    transition: color 0.15s;
  }

  .post-card:hover .post-title { color: var(--accent); }

  .post-desc {
    font-size: 0.975rem;
    color: var(--dim);
    line-height: 1.6;
    max-width: 680px;
    margin-bottom: 1rem;
  }

  .post-read {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
  }
</style>
