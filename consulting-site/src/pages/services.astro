---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Services" description="Consulting packages — Discovery Audit, Project Engagement, and Advisory Retainer.">

  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Engagements</div>
      <h1>Three ways to work together.</h1>
      <p class="hero-sub">Every engagement starts with understanding your actual system — not a generic assessment. Pricing reflects scope, not hours.</p>
    </div>
  </section>

  <!-- Discovery -->
  <section class="section" id="discovery">
    <div class="container">
      <div class="engagement">
        <div class="engagement-header">
          <div class="engagement-num">01</div>
          <div>
            <div class="engagement-label">Entry point · Best for first-time clients</div>
            <h2 class="engagement-title">Discovery Audit</h2>
            <div class="engagement-price">From $2,000</div>
          </div>
        </div>
        <div class="engagement-body">
          <div class="engagement-desc">
            <p>
              A structured deep-dive into your current infrastructure and engineering workflows.
              Woodhead Tech maps your system, identifies where manual work accumulates, and assesses
              where AI integration would deliver real ROI — not where it looks impressive.
            </p>
            <p>
              The output is a written report you keep. It includes prioritized automation
              opportunities, an AI integration roadmap with honest feasibility assessments,
              and architecture recommendations with specific tooling choices.
            </p>
            <p>
              Most clients use the Discovery report to get internal buy-in, then move into a
              Project Engagement to execute the highest-value item.
            </p>
          </div>
          <div class="engagement-includes card">
            <div class="includes-label">What's included</div>
            <ul class="includes-list">
              <li>Pre-audit questionnaire &amp; async system review</li>
              <li>3-hour working session (architecture walkthrough + Q&amp;A)</li>
              <li>Written automation opportunity report</li>
              <li>AI integration roadmap with priority ranking</li>
              <li>Tooling recommendations with rationale</li>
              <li>30-day follow-up window for questions</li>
            </ul>
            <a href="/contact" class="btn btn-outline" style="margin-top: 1.5rem;">Book a Discovery →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Project -->
  <section class="section" id="project">
    <div class="container">
      <div class="engagement">
        <div class="engagement-header">
          <div class="engagement-num accent">02</div>
          <div>
            <div class="engagement-label">Most common · 4–8 weeks</div>
            <h2 class="engagement-title">Project Engagement</h2>
            <div class="engagement-price">$10,000–25,000</div>
          </div>
        </div>
        <div class="engagement-body">
          <div class="engagement-desc">
            <p>
              Design and build one specific automation system or AI integration — from
              architecture decisions through production delivery. Scope is fixed upfront:
              you know exactly what you're getting and when.
            </p>
            <p>
              Typical projects: custom CI/CD automation, AI-powered incident triage, internal
              tooling with LLM integration, certificate lifecycle automation, infrastructure
              observability pipelines, or custom API integrations with AI decision layers.
            </p>
            <p>
              Projects start with a scope definition session. I build, you own. Price is based
              on scope — not on how many calls we have.
            </p>
          </div>
          <div class="engagement-includes card featured-card">
            <div class="includes-label">What's included</div>
            <ul class="includes-list">
              <li>Scope definition session (written spec, agreed upfront)</li>
              <li>Architecture design with decision documentation</li>
              <li>Full implementation with tests</li>
              <li>Deployment to your environment</li>
              <li>Runbook and operational documentation</li>
              <li>30-day support window post-delivery</li>
              <li>All code &amp; IP transfers to you on completion</li>
            </ul>
            <div class="payment-note">50% upfront · 50% on delivery</div>
            <a href="/contact" class="btn btn-primary" style="margin-top: 1.5rem;">Start a Project →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Retainer -->
  <section class="section" id="retainer">
    <div class="container">
      <div class="engagement">
        <div class="engagement-header">
          <div class="engagement-num">03</div>
          <div>
            <div class="engagement-label">Ongoing · Monthly</div>
            <h2 class="engagement-title">Advisory Retainer</h2>
            <div class="engagement-price">$3,000<span style="font-size: 1rem; font-weight: 400; color: var(--muted)">/mo</span></div>
          </div>
        </div>
        <div class="engagement-body">
          <div class="engagement-desc">
            <p>
              Senior systems architecture expertise without the full-time headcount. A monthly
              retainer gives your team a dedicated line to someone who can review architecture
              decisions, unblock hard problems, and provide a second opinion before you commit
              to a design.
            </p>
            <p>
              Best fit for teams that have ongoing architectural questions, are actively building
              new systems, or want an experienced engineer reviewing decisions asynchronously
              rather than interrupting their team leads.
            </p>
            <p>
              Intro rate: <strong style="color: var(--accent)">$2,000/mo for the first 3 months.</strong>
            </p>
          </div>
          <div class="engagement-includes card">
            <div class="includes-label">What's included</div>
            <ul class="includes-list">
              <li>10 hours/month (async + sync)</li>
              <li>Async Slack/email questions answered within 24hrs</li>
              <li>Monthly 60-minute strategy call</li>
              <li>Architecture reviews (PRDs, design docs, RFCs)</li>
              <li>Vendor evaluation support</li>
              <li>Rolling month-to-month, cancel anytime</li>
            </ul>
            <a href="/contact" class="btn btn-outline" style="margin-top: 1.5rem;">Ask about the retainer →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container">
      <h2 class="faq-title">Common questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>Do you work with companies that have existing engineers?</h3>
          <p>Yes — this works best when you have engineers who can execute. I design the system and help with the hard parts; your team maintains it after delivery.</p>
        </div>
        <div class="faq-item">
          <h3>What industries do you work with?</h3>
          <p>Engineering-led companies of any vertical. Deep familiarity with cloud infrastructure, SaaS, and regulated environments (FedRAMP, GovCloud).</p>
        </div>
        <div class="faq-item">
          <h3>Is there a minimum engagement?</h3>
          <p>The Discovery Audit is the minimum. Most clients start there and move into a project.</p>
        </div>
        <div class="faq-item">
          <h3>Do you do staff augmentation?</h3>
          <p>No. Woodhead Tech works on defined scopes with defined outcomes — not as a contractor embedding in your team long-term.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
  }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 560px;
    line-height: 1.7;
  }

  /* Engagement layout */
  .engagement { max-width: 960px; }

  .engagement-header {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .engagement-num {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--border);
    line-height: 1;
    flex-shrink: 0;
    font-family: monospace;
  }

  .engagement-num.accent { color: var(--accent); }

  .engagement-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .engagement-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 0.5rem;
  }

  .engagement-price {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
  }

  .engagement-body {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  .engagement-desc p {
    color: var(--dim);
    margin-bottom: 1rem;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .engagement-includes { padding: 1.75rem; }

  .featured-card {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), 0 8px 32px rgba(181, 85, 26, 0.08);
  }

  .includes-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .includes-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .includes-list li {
    font-size: 0.88rem;
    color: var(--dim);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .includes-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.8rem;
  }

  .payment-note {
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: var(--muted);
    font-style: italic;
  }

  .divider {
    border-top: 1px solid var(--border);
    max-width: 1100px;
    margin: 0 auto;
  }

  /* FAQ */
  .faq-section { background: var(--surface); border-top: 1px solid var(--border); }

  .faq-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 2.5rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 2rem;
  }

  .faq-item h3 { font-size: 1rem; margin-bottom: 0.5rem; }

  .faq-item p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }

  @media (max-width: 768px) {
    .engagement-body { grid-template-columns: 1fr; }
    .engagement-header { gap: 1rem; }
    .engagement-num { font-size: 2.5rem; }
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>
