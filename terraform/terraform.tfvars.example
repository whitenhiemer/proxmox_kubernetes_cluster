# terraform.tfvars.example - Copy to terraform.tfvars and fill in your values

# --- Proxmox Connection ---
proxmox_endpoint  = "https://pve.example.com:8006"
proxmox_api_token = "root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure  = true

# --- Proxmox Infrastructure ---
proxmox_node = "pve"
datastore    = "ceph-pool"
talos_iso    = "local:iso/talos-amd64.iso"

# --- Network ---
network_bridge  = "vmbr0"
network_gateway = "10.0.0.1"
network_subnet  = 24
nameservers     = ["10.0.0.1", "8.8.8.8"]

# --- Cluster ---
cluster_name = "talos-proxmox"
cluster_vip  = "10.0.0.100"

# --- Control Plane ---
controlplane_count = 1
controlplane_cores = 2
controlplane_memory = 4096
controlplane_disk_size = 50
controlplane_ips = ["10.0.0.101"]

# --- Workers ---
worker_count = 2
worker_cores = 4
worker_memory = 8192
worker_disk_size = 100
worker_ips = ["10.0.0.111", "10.0.0.112"]

# --- Talos ---
talos_version = "v1.9.0"

# --- LXC Containers ---
lxc_storage      = "local-lvm"
debian_template  = "local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst"
ssh_public_key   = "ssh-ed25519 AAAA... your-key-here"

# Traefik reverse proxy (front door for all web traffic)
traefik_vmid = 200
traefik_ip   = "10.0.0.20"

# Recipe site
recipe_site_vmid = 201
recipe_site_ip   = "10.0.0.21"

# ARR media management stack (Sonarr, Radarr, Prowlarr, etc.)
arr_vmid     = 202
arr_ip       = "10.0.0.22"
arr_cores    = 2
arr_memory   = 4096
arr_disk_size = 20

# --- TrueNAS Scale NAS ---
# Centralized storage for media, backups, ISOs
# Data disks are passed through manually after VM creation (see docs/TRUENAS-SETUP.md)
truenas_vmid      = 300
truenas_iso       = "local:iso/TrueNAS-SCALE.iso"
truenas_cores     = 4
truenas_memory    = 8192
truenas_disk_size = 16    # OS disk only; data goes on passthrough ZFS disks
truenas_ip        = "10.0.0.30"

# --- Home Assistant OS ---
# Pre-built disk image (no ISO install). Terraform downloads + imports automatically.
# Update the image URL when new HAOS versions are released.
homeassistant_vmid      = 301
homeassistant_image_url = "https://github.com/home-assistant/operating-system/releases/download/14.2/haos_ova-14.2.qcow2.xz"
homeassistant_cores     = 2
homeassistant_memory    = 2048
homeassistant_disk_size = 32
homeassistant_ip        = "10.0.0.31"

# --- OPNsense Firewall/Router ---
# VM ID 100 = highest boot priority
opnsense_vmid       = 100
opnsense_iso        = "local:iso/OPNsense-dvd-amd64.iso"
opnsense_cores      = 2
opnsense_memory     = 4096
opnsense_disk_size  = 16
opnsense_wan_bridge = "vmbr1"   # Separate bridge to ISP modem
opnsense_lan_ip     = "10.0.0.1"

# --- Domain ---
domain     = "woodhead.tech"
acme_email = "admin@woodhead.tech"
