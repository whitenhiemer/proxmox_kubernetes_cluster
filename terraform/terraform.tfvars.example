# terraform.tfvars.example - Copy to terraform.tfvars and fill in your values

# --- Proxmox Connection ---
proxmox_endpoint  = "https://pve.example.com:8006"
proxmox_api_token = "root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure  = true

# --- Proxmox Infrastructure ---
proxmox_node = "pve"
datastore    = "ceph-pool"
talos_iso    = "local:iso/talos-amd64.iso"

# --- Node Assignments (optional) ---
# Distribute LXC containers across cluster nodes.
# Omit or leave empty to deploy everything on proxmox_node.
# node_assignments = {
#   traefik     = "pve1"
#   recipe_site = "pve1"
#   arr         = "pve2"
#   plex        = "pve2"
#   monitoring  = "pve2"
#   jellyfin    = "pve3"
#   openclaw    = "pve3"
#   authelia    = "pve1"
# }

# --- Network ---
network_bridge  = "vmbr0"
network_gateway = "192.168.86.1"
network_subnet  = 24
nameservers     = ["192.168.86.1", "8.8.8.8"]

# --- Cluster ---
cluster_name = "talos-proxmox"
cluster_vip  = "192.168.86.100"

# --- Control Plane ---
controlplane_count = 1
controlplane_cores = 2
controlplane_memory = 4096
controlplane_disk_size = 50
controlplane_ips = ["192.168.86.101"]
# Anti-affinity: pin each CP VM to a different Proxmox host.
# Index-matched to controlplane_ips. Falls back to proxmox_node if omitted.
# controlplane_nodes = ["pve1"]  # Must match Proxmox node hostnames (pvecm nodes)

# --- Workers ---
worker_count = 2
worker_cores = 4
worker_memory = 8192
worker_disk_size = 100
worker_ips = ["192.168.86.111", "192.168.86.112"]
# Anti-affinity: spread workers across remaining hosts.
# No worker should share a host with the control plane if possible.
# worker_nodes = ["pve2", "pve3"]

# --- Talos ---
talos_version = "v1.9.0"

# --- LXC Containers ---
lxc_storage      = "local-lvm"
debian_template  = "local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst"
ssh_public_key   = "ssh-ed25519 AAAA... your-key-here"

# Traefik reverse proxy (front door for all web traffic)
traefik_vmid = 200
traefik_ip   = "192.168.86.20"

# Recipe site
recipe_site_vmid = 201
recipe_site_ip   = "192.168.86.21"

# ARR media management stack (Sonarr, Radarr, Prowlarr, etc.)
arr_vmid     = 202
arr_ip       = "192.168.86.22"
arr_cores    = 2
arr_memory   = 4096
arr_disk_size = 20

# Monitoring stack (Prometheus, Grafana, Alertmanager, exporters)
monitoring_vmid     = 205
monitoring_ip       = "192.168.86.25"
monitoring_cores    = 2
monitoring_memory   = 2048
monitoring_disk_size = 20    # Prometheus TSDB, 30-day retention

# OpenClaw AI agent framework (built from source, needs LLM API keys)
openclaw_vmid     = 206
openclaw_ip       = "192.168.86.26"
openclaw_cores    = 2
openclaw_memory   = 2048
openclaw_disk_size = 20    # Source build + Docker images + workspace

# Authelia SSO gateway (centralized auth for all web services)
authelia_vmid = 207
authelia_ip   = "192.168.86.28"

# WireGuard VPN tunnel (remote LAN access, UDP 51820)
wireguard_vmid = 208
wireguard_ip   = "192.168.86.39"

# --- TrueNAS Scale NAS ---
# Centralized storage for media, backups, ISOs
# Data disks are passed through manually after VM creation (see docs/TRUENAS-SETUP.md)
truenas_vmid      = 300
truenas_iso       = "local:iso/TrueNAS-SCALE.iso"
truenas_cores     = 4
truenas_memory    = 8192
truenas_disk_size = 16    # OS disk only; data goes on passthrough ZFS disks
truenas_ip        = "192.168.86.40"

# Plex Media Server (requires Plex Pass for hardware transcoding)
plex_vmid     = 203
plex_ip       = "192.168.86.23"
plex_cores    = 2
plex_memory   = 2048
plex_disk_size = 8    # Metadata only; media on TrueNAS NFS

# Jellyfin Media Server (open source, free hardware transcoding)
jellyfin_vmid     = 204
jellyfin_ip       = "192.168.86.24"
jellyfin_cores    = 2
jellyfin_memory   = 2048
jellyfin_disk_size = 8

# --- Home Assistant OS ---
# Pre-built disk image (no ISO install). Terraform downloads + imports automatically.
# Update the image URL when new HAOS versions are released.
homeassistant_vmid      = 301
homeassistant_image_url = "https://github.com/home-assistant/operating-system/releases/download/14.2/haos_ova-14.2.qcow2.xz"
homeassistant_cores     = 2
homeassistant_memory    = 2048
homeassistant_disk_size = 32
homeassistant_ip        = "192.168.86.41"

# --- Domain ---
domain     = "woodhead.tech"
acme_email = "admin@woodhead.tech"
