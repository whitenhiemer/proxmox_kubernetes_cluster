# cloudflare.env - Cloudflare DDNS configuration
#
# Copy to /etc/ddns/cloudflare.env on your Proxmox host.
# Permissions should be 600 (root-only readable).
#
# To get these values:
#   1. Log into Cloudflare dashboard
#   2. Select woodhead.tech zone
#   3. Zone ID is on the right sidebar of the Overview page
#   4. Create an API token: My Profile > API Tokens > Create Token
#      - Use "Edit zone DNS" template
#      - Scope to woodhead.tech zone only

# Cloudflare API token with Zone:DNS:Edit permission
CF_API_TOKEN="your-cloudflare-api-token-here"

# Zone ID for woodhead.tech (found on the Cloudflare dashboard Overview page)
CF_ZONE_ID="your-zone-id-here"

# Comma-separated list of A record names to update
# These records must already exist in Cloudflare DNS
CF_RECORD_NAMES="woodhead.tech,*.woodhead.tech"
